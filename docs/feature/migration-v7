КОНТРАКТЫ МЕЖДУ УЗЛАМИ
═══════════════════════════════════════════════════════════════════════════════

  intent_gate:
    reads:   query
    writes:  intent

  router:
    reads:   query, filters
    writes:  plan, retrieval_id, active_query, verify_iteration, clarify_message

  rag_simple:
    reads:   active_query, filters, plan, retrieval_id, retrieval_attempts, query
    writes:  retrieval_attempts (append with attempt_plan + metrics)

  evaluate_triage:
    reads:   query, active_query, retrieval_attempts[-1]
    writes:  sufficient, sufficiency_details, final_passages, final_score,
             fallback_passages, fallback_score
    uses:    check_full_triage() — hard gates + soft signals + triage label
    note:    plan from attempt_plan snapshot

  llm_verifier:
    reads:   query, active_query, retrieval_attempts[-1], verify_iteration
    writes:  verification, sufficient, final_passages, final_score

  rewriter:
    reads:   query, active_query, verification, filters
    writes:  active_query, retrieval_id, verify_iteration

  rag_complex:
    reads:   query, active_query, filters, plan
    writes:  plan, retrieval_attempts (append with attempt_plan + metrics)

  evaluate_complex:
    reads:   query, active_query, retrieval_attempts[-1],
             fallback_passages, fallback_score
    writes:  sufficient, final_passages, final_score, sufficiency_details
    uses:    check_hard_gates() — NO triage, NO soft signals
    note:    plan from attempt_plan snapshot; fallback on complex failure

  abstain:
    reads:   query, active_query, retrieval_attempts, sufficiency_details,
             plan, verification, verify_iteration
    writes:  abstain_reason

