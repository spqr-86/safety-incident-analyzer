# GRAPH ASSEMBLY
# ═══════════════════════════════════════════════════════════════════════════════

def build_graph(overrides: Optional[Dict[str, Any]] = None) -> StateGraph:
    """
    Граф v7. overrides: dict of {node_name: replacement_function}.
    Убирает копипасту сборки графа в examples/tests.

    Usage:
        app = build_graph().compile()
        custom = build_graph({"router": my_router, "llm_verifier": my_verifier}).compile()
    """
    nodes = {
        "intent_gate": intent_gate,
        "router": router,
        "clarify_respond": clarify_respond,
        "rag_simple": rag_simple,
        "evaluate_triage": evaluate_triage,
        "llm_verifier": llm_verifier,
        "rewriter": rewriter,
        "rag_complex": rag_complex,
        "evaluate_complex": evaluate_complex,
        "abstain": abstain,
    }
    if overrides:
        nodes.update(overrides)

    g = StateGraph(RAGState)
    for name, func in nodes.items():
        g.add_node(name, func)

    g.set_entry_point("intent_gate")

    g.add_conditional_edges("intent_gate", route_by_intent,
                            {"end": END, "router": "router"})
    g.add_conditional_edges("router", route_after_router,
                            {"clarify_respond": "clarify_respond", "rag_simple": "rag_simple"})
    g.add_edge("clarify_respond", END)
    g.add_edge("rag_simple", "evaluate_triage")
    g.add_conditional_edges("evaluate_triage", route_after_triage,
                            {"end": END, "llm_verifier": "llm_verifier", "rag_complex": "rag_complex"})
    g.add_conditional_edges("llm_verifier", route_after_verifier,
                            {"end": END, "rewriter": "rewriter", "rag_complex": "rag_complex"})
    g.add_edge("rewriter", "rag_simple")
    g.add_edge("rag_complex", "evaluate_complex")
    g.add_conditional_edges("evaluate_complex", route_after_eval_complex,
                            {"end": END, "abstain": "abstain"})
    g.add_edge("abstain", END)

    return g


app = build_graph().compile()


