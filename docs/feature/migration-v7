def _classify_query(q: str) -> tuple[bool, float]:
    """
    Классификация запроса для router.

    Returns:
        (require_multi_doc, mmr_lambda)

    require_multi_doc: True для запросов-сравнений.
    mmr_lambda: 0.9-1.0 для factoid (конкретная цифра/пункт),
                0.5-0.6 для overview (обзор темы, сравнение).

    Заглушка: keyword-based. Production: LLM-классификатор.
    """
    q_lower = q.lower()

    COMPARISON_MARKERS = {
        "сравни", "разница", "отличие", "коллизия", "приоритет",
        "что важнее", "противореч", "различия", "vs", "или лучше",
    }
    is_comparison = any(m in q_lower for m in COMPARISON_MARKERS)

    FACTOID_MARKERS = {
        "пункт", "п.", "таблица", "табл.", "значение", "величина",
        "минимальн", "максимальн", "не менее", "не более", "сколько",
    }
    is_factoid = any(m in q_lower for m in FACTOID_MARKERS)

    if is_comparison:
        return True, 0.5
    elif is_factoid:
        return False, 0.95
    else:
        return False, 0.7  # default balanced


def router(state: RAGState) -> RAGState:
    """
    Reads: query, filters.
    Writes: plan, retrieval_id, active_query, verify_iteration.
    Cleans: clarify_message, abstain_reason, fallback_passages (state hygiene).

    v6.1: query classification → require_multi_doc, mmr_lambda.
    """
    q = (state.get("query") or "").strip()
    filters = state.get("filters")

    if len(q) < 8:
        return {
            "clarify_message": (
                "Уточните, пожалуйста, ваш запрос. "
                "Например: какой нормативный документ или тему вы имеете в виду?"
            ),
        }

    require_multi, mmr_lambda = _classify_query(q)

    plan: RetrievalPlan = {
        "top_k": 12,
        "rerank": False,
        "timeout_ms": 250,
        "threshold": 0.45,
        "min_passages": 5,
        "min_keyword_overlap": 0.3,
        "max_single_doc_ratio": 0.8,
        "borderline_threshold": 0.25,
        "min_verifier_confidence": 0.5,
        "require_multi_doc": require_multi,
        "mmr_lambda": mmr_lambda,
    }

    return {
        "plan": plan,
        "retrieval_id": make_retrieval_id(q, filters),
        "active_query": q,
        "verify_iteration": 0,
        # State cleanup: сброс полей от предыдущих runs (persistent state)
        "clarify_message": None,
        "abstain_reason": None,
        "fallback_passages": None,
        "fallback_score": None,
    }


def route_after_router(state: RAGState) -> NextAfterRouter:
    return "clarify_respond" if state.get("clarify_message") else "rag_simple"


