def mmr_select(
    passages: List[dict],
    top_k: int,
    lambda_param: float = 0.7,
) -> List[dict]:
    """
    Maximal Marginal Relevance — FALLBACK ONLY.

    В production основной MMR делает Chroma/Qdrant нативно:
      collection.query(n_results=top_k, mmr=True)
    Этот mmr_select используется ТОЛЬКО в merge_all_passages(),
    где нет доступа к VectorDB (passages уже извлечены).

    Заглушка: doc_id diversity penalty. Production: cosine similarity
    между embeddings passages."""
    if len(passages) <= top_k:
        return passages

    selected: List[dict] = []
    remaining = list(passages)
    selected_doc_ids: Counter = Counter()

    for _ in range(top_k):
        best_idx = -1
        best_mmr = -1.0

        for i, p in enumerate(remaining):
            relevance = p.get("score", 0.0)
            doc_id = p.get("doc_id", "unknown")

            # Штраф за повтор doc_id: чем больше чанков из этого doc уже выбрано,
            # тем сильнее штраф. diversity_penalty ∈ [0, 1].
            doc_count = selected_doc_ids.get(doc_id, 0)
            diversity_penalty = doc_count / max(len(selected), 1)

            mmr_score = lambda_param * relevance - (1 - lambda_param) * diversity_penalty

            if mmr_score > best_mmr:
                best_mmr = mmr_score
                best_idx = i

        if best_idx < 0:
            break

        chosen = remaining.pop(best_idx)
        selected.append(chosen)
        selected_doc_ids[chosen.get("doc_id", "unknown")] += 1

    return selected


def _lemmatize_for_bm25(text: str) -> List[str]:
    """Токенизация + лемматизация для BM25 индекса и запросов."""
    tokens = []
    for token in razdel_tokenize(text):
        word = token.text.lower()
        if len(word) < 2 or not re.match(r"[а-яёa-z0-9]", word):
            continue
        parsed = _morph.parse(word)
        lemma = parsed[0].normal_form if parsed else word
        tokens.append(lemma)
    return tokens


class BM25Index:
    """
    BM25 индекс поверх rank_bm25.BM25Okapi с pymorphy3 лемматизацией.

    Usage:
        index = BM25Index(passages)  # build once
        results = index.search(query, top_k=12)
    """

    def __init__(self, passages: List[dict]):
        self._passages = passages
        corpus = [_lemmatize_for_bm25(p.get("text", "")) for p in passages]
        self._bm25 = BM25Okapi(corpus)

    def search(
        self,
        query: str,
        top_k: int = 12,
        filters: Optional[dict] = None,
    ) -> List[dict]:
        tokens = _lemmatize_for_bm25(query)
        if not tokens:
            return []
        scores = self._bm25.get_scores(tokens)
        # Apply filters if provided
        candidates = []
        for i, score in enumerate(scores):
            p = self._passages[i]
            if filters:
                skip = False
                for k, v in filters.items():
                    if p.get(k) != v:
                        skip = True
                        break
                if skip:
                    continue
            candidates.append((i, score))

        candidates.sort(key=lambda x: x[1], reverse=True)
        results = []
        for idx, score in candidates[:top_k]:
            p = dict(self._passages[idx])
            p["bm25_score"] = round(float(score), 4)
            if "score" not in p:
                p["score"] = p["bm25_score"]
            results.append(p)
        return results


# ─── Global BM25 index (populated at startup, stub for now) ─────────────────
_bm25_index: Optional[BM25Index] = None


def init_bm25_index(passages: List[dict]) -> None:
    """Initialize global BM25 index. Call once at startup with full corpus."""
    global _bm25_index
    _bm25_index = BM25Index(passages)


def bm25_search(
    query: str,
    filters: Optional[dict],
    top_k: int,
) -> List[dict]:
    """
    BM25 full-text search с pymorphy3 лемматизацией.

    v7: реальный rank_bm25.BM25Okapi вместо заглушки.
    Требует предварительной init_bm25_index() с корпусом.
    Fallback: если индекс не инициализирован, возвращает stub.
    """
    if _bm25_index is not None:
        return _bm25_index.search(query, top_k, filters)

    # Stub fallback (для examples/tests без реального корпуса)
    snippet = query if len(query) < 120 else query[:120]
    return [
        {
            "chunk_id": f"bm25_{i:03d}",
            "doc_id": f"doc_{i // 4 + 1:03d}",
            "score": round(0.68 - i * 0.025, 3),
            "text": f"[bm25-stub] п.{i+1}. {snippet}. Нормативные положения.",
        }
        for i in range(top_k)
    ]


def rrf_merge(
    *result_lists: List[dict],
    top_k: int = 12,
    k: int = 60,
) -> List[dict]:
    """
    Reciprocal Rank Fusion — объединяет results из нескольких retriever-ов.

    RRF score = Σ 1 / (k + rank_i) по всем спискам.
    k=60 — стандартное значение (оригинальная статья Cormack et al.).

    Дедуп по chunk_id: один passage считается по лучшему rank.
    """
    chunk_scores: Dict[str, float] = {}
    chunk_map: Dict[str, dict] = {}

    for results in result_lists:
        for rank, p in enumerate(results):
            cid = p.get("chunk_id", f"unknown_{rank}")
            rrf_score = 1.0 / (k + rank + 1)
            if cid not in chunk_scores or rrf_score > chunk_scores[cid]:
                chunk_scores[cid] = chunk_scores.get(cid, 0.0) + rrf_score
                chunk_map[cid] = p

    # Sort by RRF score, update passage score for downstream
    ranked = sorted(chunk_scores.items(), key=lambda x: x[1], reverse=True)[:top_k]
    result = []
    for cid, score in ranked:
        p = dict(chunk_map[cid])
        p["rrf_score"] = round(score, 5)
        result.append(p)

    return result


def retrieve(
    query: str,
    filters: Optional[dict],
    top_k: int,
    timeout_ms: int,
    rerank: bool = False,
    mmr: bool = False,
    mmr_lambda: float = 0.7,
) -> List[dict]:
    """
    Заглушка retriever. Production: Chroma/Qdrant + BM25 hybrid + ColBERT rerank.

    v6.1: mmr_fetch_k вычисляется внутри (3x top_k при mmr=True).
    Снаружи передаётся только top_k и mmr=True/False.
    """
    time.sleep(timeout_ms / 1000 * 0.1)
    snippet = query if len(query) < 120 else query[:120]

    fetch_k = top_k * 3 if mmr else top_k

    passages = [
        {
            "chunk_id": f"chunk_{i:03d}",
            "doc_id": f"doc_{i // 5 + 1:03d}",
            "score": round(0.72 - i * 0.02, 3),
            "text": f"[stub] п.{i+1}.{i+2}. {snippet}. Нормативные положения.",
        }
        for i in range(fetch_k)
    ]

    if rerank:
        import random
        rng = random.Random(42)
        for p in passages:
            p["score"] = round(p["score"] + rng.uniform(-0.05, 0.08), 3)
        passages = sorted(passages, key=lambda x: x["score"], reverse=True)

    if mmr:
        passages = mmr_select(passages, top_k, mmr_lambda)
    else:
        passages = sorted(passages, key=lambda x: x.get("score", 0.0), reverse=True)[:top_k]

    return passages


