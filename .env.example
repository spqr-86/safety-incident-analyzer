# ===================================================================
# Конфигурация для Safety Incident Analyzer
# ===================================================================
# Скопируйте этот файл в .env и заполните своими ключами

# -------------------------------------------------------------------
# LLM Provider (openai)
# -------------------------------------------------------------------
LLM_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.0

# -------------------------------------------------------------------
# OpenAI (для LLM и эмбеддингов)
# -------------------------------------------------------------------
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# -------------------------------------------------------------------
# Embeddings Provider (openai | hf_api | local)
# -------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small

# -------------------------------------------------------------------
# LangSmith (для eval и трассировки)
# -------------------------------------------------------------------
# Получить ключ: https://smith.langchain.com/
LANGSMITH_API_KEY=YOUR_LANGSMITH_KEY_HERE
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=safety-incident-analyzer

# -------------------------------------------------------------------
# Google Gemini
# -------------------------------------------------------------------
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_FAST_MODEL=gemini-3-flash-preview

# -------------------------------------------------------------------
# Weights & Biases (опционально, для experiment tracking)
# -------------------------------------------------------------------
# WANDB_API_KEY=YOUR_WANDB_KEY_HERE
# WANDB_PROJECT=safety-incident-analyzer

# -------------------------------------------------------------------
# Пути и конфигурация
# -------------------------------------------------------------------
SOURCE_DOCS_PATH=./source_docs
CHROMA_DB_PATH=./chroma_db_openai
CHROMA_COLLECTION_NAME=documents

# Параметры chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Параметры retrieval
VECTOR_SEARCH_K=40
HYBRID_RETRIEVER_WEIGHTS=[0.5, 0.5]

# -------------------------------------------------------------------
# Примечания
# -------------------------------------------------------------------
# 1. Минимально для работы нужны:
#    - OPENAI_API_KEY (для LLM и эмбеддингов)
#
# 2. Для evaluation дополнительно:
#    - LANGSMITH_API_KEY (для run_ab_test.py)
#
# 3. Для production мониторинга:
#    - WANDB_API_KEY (опционально)
