[Фрагмент {{ loop.index }}]
Источник: {{ chunk.source }}{% if chunk.page_no %} (стр. {{ chunk.page_no }}){% endif %}{% if chunk.similarity %} | Релевантность: {{ "%.2f"|format(chunk.similarity) }}{% endif %}

{{ chunk.content }}
