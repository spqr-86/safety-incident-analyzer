# ВОПРОС ПОЛЬЗОВАТЕЛЯ
{{ query }}

# НАЙДЕННЫЕ ФРАГМЕНТЫ ДОКУМЕНТОВ
{% if context %}
{% for chunk in context %}
[Фрагмент {{ loop.index }}]
Источник: {{ chunk.source }}{% if chunk.page_no %} (стр. {{ chunk.page_no }}){% endif %}{% if chunk.similarity %} | Релевантность: {{ "%.2f"|format(chunk.similarity) }}{% endif %}

{{ chunk.content }}
{% if chunk.visual_text %}
[Визуальный анализ]: {{ chunk.visual_text }}
{% endif %}
